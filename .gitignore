.env.local
.env.*.local
*.env
media-config.json
.mcp.json
apps/daemon/uploads/

# Landing-page preview thumbnails — regenerated by CI from
# `skills/<slug>/example.html` and `templates/live-artifacts/<slug>/`
# on every deploy. Should not be committed (~70MB of PNGs).
apps/landing-page/public/previews/

